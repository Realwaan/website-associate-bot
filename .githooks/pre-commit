#!/usr/bin/env sh
set -eu

echo "[pre-commit] Running secret scan..."

if command -v python >/dev/null 2>&1; then
  python scripts/check_secrets.py
elif command -v py >/dev/null 2>&1; then
  py -3 scripts/check_secrets.py
else
  echo "[pre-commit] Python was not found on PATH. Aborting commit."
  exit 1
fi

echo "[pre-commit] Secret scan passed."
