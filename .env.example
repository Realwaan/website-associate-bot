# Copy this file to .env for local development.
# In Render, set these as environment variables in the service dashboard.

# Discord Bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Supabase Session Pooler connection string (required)
# Format: postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.yourprojectref:your_db_password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# GitHub Personal Access Token (required for /update-project and /auto-updates)
GITHUB_TOKEN=your_github_pat_here

# Keep-alive web endpoint settings
# Local default: false. Render auto-enables this unless overridden.
KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_HOST=0.0.0.0
KEEP_ALIVE_PORT=8080

# Database timeout safeguards
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=15000

# ===========================================================================
# NVIDIA AI — Four-Profile Layout (recommended)
# ===========================================================================
# Each capability can use its own model and API key.
# Per-profile keys take priority; the legacy NVIDIA_* keys are the fallback.
#
# AI_DEFAULT_PROFILE selects which profile /ask-ai uses by default.
# Valid values: answer | code | scan_docs | rag  (default: answer)
AI_DEFAULT_PROFILE=answer

# --- answer profile: used by /ask-ai ---
AI_ANSWER_API_KEY=nvapi-your-key-here
AI_ANSWER_MODEL=google/gemma-4-31b-it
AI_ANSWER_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
AI_ANSWER_TIMEOUT_SECONDS=45

# --- code profile: reserved for future coding-focused commands ---
AI_CODE_API_KEY=nvapi-your-key-here
AI_CODE_MODEL=qwen/qwen2.5-coder-32b-instruct
AI_CODE_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
AI_CODE_TIMEOUT_SECONDS=60

# --- scan_docs profile: used by /scan-pdf (multimodal vision) ---
AI_SCAN_DOCS_API_KEY=nvapi-your-key-here
AI_SCAN_DOCS_MODEL=meta/llama-4-scout-17b-16e-instruct
AI_SCAN_DOCS_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
AI_SCAN_DOCS_TIMEOUT_SECONDS=90

# --- rag profile: reserved for future retrieval-augmented commands ---
AI_RAG_API_KEY=nvapi-your-key-here
AI_RAG_MODEL=google/gemma-4-31b-it
AI_RAG_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
AI_RAG_TIMEOUT_SECONDS=60

# ===========================================================================
# NVIDIA AI — Legacy Single-Key Fallback (backwards-compatible)
# ===========================================================================
# If no per-profile key is set, the client falls back to these values.
# You can use just these three keys and every profile will share the same model.
NVIDIA_API_KEY=
NVIDIA_MODEL=google/gemma-4-31b-it
NVIDIA_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_TIMEOUT_SECONDS=45

# PDF scanner OCR fallback (optional)
# Set false to disable OCR fallback for scanned/image-only PDFs.
ENABLE_PDF_OCR_FALLBACK=true
# Optional explicit path to Tesseract executable.
# Examples:
# Windows: C:\\Program Files\\Tesseract-OCR\\tesseract.exe
# Linux: /usr/bin/tesseract
TESSERACT_CMD=
