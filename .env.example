# Copy this file to .env for local development.
# In Render, set these as environment variables in the service dashboard.

# Discord Bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Supabase Session Pooler connection string (required)
# Format: postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.yourprojectref:your_db_password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Keep-alive web endpoint settings
# Local default: false. Render auto-enables this unless overridden.
KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_HOST=0.0.0.0
KEEP_ALIVE_PORT=8080

# Database timeout safeguards
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=15000
